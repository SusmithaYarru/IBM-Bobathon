# Agent Layer — Environment Variables
# Copy this file to .env and fill in your credentials

# ── IBM watsonx.ai ───────────────────────────────────────────────────────────
WATSONX_API_KEY=your-ibm-cloud-api-key-here
WATSONX_PROJECT_ID=your-watsonx-project-id-here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# ── Stub / offline mode ───────────────────────────────────────────────────────
# Stub mode is ON by default (no .env file needed for demo).
# To switch to LIVE watsonx.ai mode, set this to false and add your API key above.
WATSONX_STUB=false

# ── Server config ─────────────────────────────────────────────────────────────
AGENT_PORT=4000
AGENT_HOST=0.0.0.0

# ── IBM ACE integration server ────────────────────────────────────────────────
ACE_BASE_URL=http://localhost:7080

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
